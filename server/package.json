{
  "name": "roommatepunishment-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:scheduler": "node dist/scheduler-worker.js",
    "test": "npm run build && vitest run",
    "test:coverage": "npm run build && vitest run --coverage",
    "seed": "tsx src/db/seed.ts",
    "reseed:household": "tsx scripts/reseed-household.ts",
    "db:bootstrap-neon": "node scripts/bootstrap-neon.mjs",
    "simulate:whatsapp": "tsx scripts/simulate-whatsapp-flow.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "openai": "^6.32.0",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "whatsapp-web.js": "^1.34.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.10",
    "@types/pg": "^8.18.0",
    "@types/qrcode": "^1.5.5",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^4.1.0"
  }
}
